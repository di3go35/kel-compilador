fn mul(a: int, b: int) -> int {
  t1 = a * b
  return t1
}

fn div(a: int, b: int) -> int {
  t1 = a / b
  return t1
}

fn neg(a: int) -> int {
  t1 = -a
  return t1
}

fn cadena(s: string) -> string {
  t1 = s + "!"
  return t1
}

